@page
@model TestingSystem.Pages.Admin.Disciplines.CreateModel
@{
    ViewData["Title"] = "Создание дисциплины";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h1 class="mb-4">📚 Создание новой дисциплины</h1>

        <div class="card">
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Name" class="form-label"></label>
                        <input asp-for="Input.Name" class="form-control" placeholder="Например: C# Программирование" />
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <textarea asp-for="Input.Description" class="form-control" rows="4"
                                  placeholder="Описание дисциплины..."></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.TeacherId" class="form-label"></label>
                        <select asp-for="Input.TeacherId" class="form-select" asp-items="Model.TeachersSelectList">
                            <option value="">-- Выберите преподавателя (необязательно) --</option>
                        </select>
                        <span asp-validation-for="Input.TeacherId" class="text-danger"></span>
                        <small class="text-secondary">Можно назначить преподавателя позже</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">💾 Создать</button>
                        <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>