@page "{id:int}"
@model TestingSystem.Pages.Admin.Disciplines.DeleteModel
@{
    ViewData["Title"] = "Удаление дисциплины";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h1 class="mb-4">🗑️ Удаление дисциплины</h1>

        <div class="card border-danger">
            <div class="card-body">
                <div class="alert alert-danger">
                    <strong>Внимание!</strong> Вы собираетесь удалить дисциплину. Все связанные тесты и результаты будут также удалены.
                </div>

                <dl class="row">
                    <dt class="col-sm-4">ID:</dt>
                    <dd class="col-sm-8">@Model.Discipline.Id</dd>

                    <dt class="col-sm-4">Название:</dt>
                    <dd class="col-sm-8">@Model.Discipline.Name</dd>

                    <dt class="col-sm-4">Преподаватель:</dt>
                    <dd class="col-sm-8">@(Model.Discipline.TeacherName ?? "Не назначен")</dd>

                    <dt class="col-sm-4">Студентов:</dt>
                    <dd class="col-sm-8">@Model.StudentsCount</dd>
                </dl>

                <form method="post">
                    <input type="hidden" name="id" value="@Model.Discipline.Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">🗑️ Да, удалить</button>
                        <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>