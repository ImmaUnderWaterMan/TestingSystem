@page
@model TestingSystem.Pages.Admin.Disciplines.IndexModel
@{
    ViewData["Title"] = "Управление дисциплинами";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1> Управление дисциплинами</h1>
    <a asp-page="Create" class="btn btn-success">+ Добавить дисциплину</a>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-@(Model.MessageType) alert-dismissible fade show">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        @if (Model.Disciplines.Any())
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Название</th>
                        <th>Описание</th>
                        <th>Преподаватель</th>
                        <th>Дата создания</th>
                        <th>Студентов</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var discipline in Model.Disciplines)
                    {
                        <tr>
                            <td>@discipline.Id</td>
                            <td><strong>@discipline.Name</strong></td>
                            <td>
                                @if (!string.IsNullOrEmpty(discipline.Description))
                                {
                                    <small class="text-secondary">
                                        @discipline.Description.Substring(0, Math.Min(50, discipline.Description.Length))...
                                    </small>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@(discipline.TeacherName ?? "Не назначен")</td>
                            <td>@discipline.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td>
                                <a asp-page="Students" asp-route-id="@discipline.Id" class="btn btn-sm btn-info">
                                    @Model.StudentsCount.GetValueOrDefault(discipline.Id, 0)
                                </a>
                            </td>
                            <td>
                                <a asp-page="/Admin/Tests/Index" asp-route-disciplineId="@discipline.Id" class="btn btn-sm btn-primary">
                                    📝 Тесты
                                </a>
                                <a asp-page="Edit" asp-route-id="@discipline.Id" class="btn btn-sm btn-outline-primary">
                                    ✏️ Изменить
                                </a>
                                <a asp-page="Delete" asp-route-id="@discipline.Id" class="btn btn-sm btn-outline-danger">
                                    🗑️ Удалить
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center text-secondary py-4">
                <div style="font-size: 48px;">📚</div>
                <p>Дисциплины ещё не созданы</p>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-page="/Index" class="btn btn-secondary">← На главную</a>
</div>