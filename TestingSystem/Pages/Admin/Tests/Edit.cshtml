@page "{id:int}"
@model TestingSystem.Pages.Admin.Tests.EditModel
@{
    ViewData["Title"] = "Редактирование теста";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h1 class="mb-4">✏️ Редактирование теста</h1>
        <h5 class="text-secondary mb-4">Дисциплина: @Model.DisciplineName</h5>

        <div class="card">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Input.Id" />
                    <input type="hidden" asp-for="Input.DisciplineId" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label text-secondary">ID теста</label>
                        <input value="@Model.Input.Id" class="form-control" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Title" class="form-label"></label>
                        <input asp-for="Input.Title" class="form-control" />
                        <span asp-validation-for="Input.Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.TimeLimitMinutes" class="form-label"></label>
                            <input asp-for="Input.TimeLimitMinutes" class="form-control" type="number" />
                            <span asp-validation-for="Input.TimeLimitMinutes" class="text-danger"></span>
                            <small class="text-secondary">Оставьте пустым, если без ограничения</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.PassingScore" class="form-label"></label>
                            <input asp-for="Input.PassingScore" class="form-control" type="number" />
                            <span asp-validation-for="Input.PassingScore" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="Input.IsPublished" class="form-check-input" />
                        <label asp-for="Input.IsPublished" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">💾 Сохранить</button>
                        <a asp-page="Index" asp-route-disciplineId="@Model.Input.DisciplineId" class="btn btn-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>