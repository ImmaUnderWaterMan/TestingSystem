@page "{id:int}"
@model TestingSystem.Pages.Admin.Users.DeleteModel
@{
    ViewData["Title"] = "Удаление пользователя";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h1 class="mb-4">🗑️ Удаление пользователя</h1>

        <div class="card border-danger">
            <div class="card-body">
                <div class="alert alert-danger">
                    <strong>Внимание!</strong> Вы собираетесь удалить пользователя. Это действие нельзя отменить.
                </div>

                <dl class="row">
                    <dt class="col-sm-4">ID:</dt>
                    <dd class="col-sm-8">@Model.UserToDelete.Id</dd>

                    <dt class="col-sm-4">Логин:</dt>
                    <dd class="col-sm-8">@Model.UserToDelete.Login</dd>

                    <dt class="col-sm-4">ФИО:</dt>
                    <dd class="col-sm-8">@Model.UserToDelete.LastName @Model.UserToDelete.FirstName</dd>

                    <dt class="col-sm-4">Роль:</dt>
                    <dd class="col-sm-8">@Model.UserToDelete.RoleName</dd>
                </dl>

                <form method="post">
                    <input type="hidden" name="id" value="@Model.UserToDelete.Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">🗑️ Да, удалить</button>
                        <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>