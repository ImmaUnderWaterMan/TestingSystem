@page
@model TestingSystem.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Управление пользователями";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1> Управление пользователями</h1>
    <a asp-page="Create" class="btn btn-success">+ Добавить пользователя</a>
</div>

<!-- Фильтр по роли -->
<form method="get" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <select name="roleId" class="form-select" onchange="this.form.submit()">
                <option value="">Все роли</option>
                @foreach (var role in Model.Roles)
                {
                    <option value="@role.Id" selected="@(Model.SelectedRoleId == role.Id)">
                        @role.Name
                    </option>
                }
            </select>
        </div>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-@(Model.MessageType) alert-dismissible fade show">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Логин</th>
                    <th>ФИО</th>
                    <th>Email</th>
                    <th>Роль</th>
                    <th>Дата создания</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td><strong>@user.Login</strong></td>
                        <td>@user.LastName @user.FirstName</td>
                        <td>@(user.Email ?? "-")</td>
                        <td>
                            <span class="badge bg-@(user.RoleName == "Admin" ? "danger" :
                                                                                    user.RoleName == "Teacher" ? "primary" : "success")">
                                @user.RoleName
                            </span>
                        </td>
                        <td>@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">
                                ✏️ Изменить
                            </a>
                            <a asp-page="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger">
                                🗑️ Удалить
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Users.Any())
        {
            <div class="text-center text-muted py-4">
                Пользователи не найдены
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-page="/Index" class="btn btn-secondary">← На главную</a>
</div>