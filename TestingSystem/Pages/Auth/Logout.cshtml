@page
@model TestingSystem.Pages.Auth.LogoutModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Выход из системы";
}

<div class="auth-icon"></div>
<h2>Выход из системы</h2>
<p class="text-muted mb-4 text-center">Вы уверены, что хотите выйти?</p>

<form method="post">
    <button type="submit" class="btn-danger-custom">
        Да, выйти
    </button>
</form>

<a href="/" class="btn-secondary-custom text-center d-block text-decoration-none">
    ← Отмена
</a>