@page "{disciplineId:int}"
@model TestingSystem.Pages.Student.TestsModel
@{
    ViewData["Title"] = $"Тесты: {Model.Discipline?.Name}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>📝 Тесты дисциплины</h1>
        <h4 class="text-secondary">@Model.Discipline?.Name</h4>
    </div>
    <a asp-page="Index" class="btn btn-secondary">← Назад к дисциплинам</a>
</div>

@if (Model.Tests.Any())
{
    <div class="row">
        @foreach (var test in Model.Tests)
        {
            var hasPassed = Model.PassedTests.Contains(test.Id);
            <div class="col-md-6 mb-4">
                <div class="card h-100 @(hasPassed ? "border-success" : "")">
                    <div class="card-body">
                        <h5 class="card-title">@test.Title</h5>
                        <p class="card-text text-secondary">
                            @(string.IsNullOrEmpty(test.Description) ? "Описание отсутствует" : test.Description)
                        </p>
                        <ul class="list-unstyled">
                            <li>⏱️ Время: @(test.TimeLimitMinutes?.ToString() ?? "∞") мин</li>
                            <li>🎯 Проходной балл: @test.PassingScore%</li>
                            <li>❓ Вопросов: @Model.QuestionsCount.GetValueOrDefault(test.Id, 0)</li>
                        </ul>

                        @if (hasPassed)
                        {
                            <div class="alert alert-success mb-2">
                                ✅ Тест уже пройден!
                            </div>
                            <a asp-page="Result" asp-route-resultId="@Model.PassedResults[test.Id]" class="btn btn-outline-success w-100">
                                📊 Посмотреть результат
                            </a>
                        }
                        else
                        {
                            <a asp-page="TakeTest" asp-route-testId="@test.Id" class="btn btn-primary w-100">
                                🚀 Начать тест
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info text-center">
        <h4>📝 В этой дисциплине пока нет тестов</h4>
    </div>
}